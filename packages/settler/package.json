{
  "name": "@updown/settler",
  "version": "0.1.0",
  "private": true,
  "description": "Up/Down permissionless settlement cron — calls predict::redeem_permissionless for expired positions",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/run.js",
  "scripts": {
    "dev": "tsx watch src/run.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/run.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten/sui": "^1.40.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
