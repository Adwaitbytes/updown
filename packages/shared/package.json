{
  "name": "@updown/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "default": "./dist/migrate.js"
    },
    "./migrations/*": "./migrations/*"
  },
  "main": "./dist/migrate.js",
  "types": "./dist/migrate.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.11.10"
  }
}
